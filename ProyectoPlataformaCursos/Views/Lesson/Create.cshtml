@model ProyectoPlataformaCursos.Models.Leccion

@{
    ViewData["Title"] = "Crear Lección";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <h2 class="card-title">Crear Nueva Lección</h2>
                    <p class="text-muted">Curso: @ViewBag.CursoTitulo</p>

                    <form asp-action="Create" method="post">
                        <input type="hidden" asp-for="IdCurso" value="@ViewBag.CursoId" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Titulo" class="form-label"></label>
                            <input asp-for="Titulo" class="form-control" placeholder="Título de la lección" />
                            <span asp-validation-for="Titulo" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Contenido" class="form-label"></label>
                            <textarea asp-for="Contenido" class="form-control" rows="10" placeholder="Contenido de la lección"></textarea>
                            <span asp-validation-for="Contenido" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Orden" class="form-label"></label>
                            <input asp-for="Orden" class="form-control" type="number" min="1" />
                            <span asp-validation-for="Orden" class="text-danger"></span>
                            <small class="form-text text-muted">Orden en el que aparecerá la lección</small>
                        </div>

                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary">Crear Lección</button>
                            <a asp-controller="Course" asp-action="Details" asp-route-id="@ViewBag.CursoId" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
