@model ProyectoPlataformaCursos.Models.Curso

@{
    ViewData["Title"] = "Detalles del Curso";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h1>@Model.Titulo</h1>
            <p class="lead">@Model.Descripcion</p>
            
            <div class="mb-3">
                <strong>Profesor:</strong> @Model.Profesor?.Nombre @Model.Profesor?.Apellidos<br />
                <strong>Fecha de Creación:</strong> @Model.FechaCreacion.ToShortDateString()<br />
                <strong>Estado:</strong> 
                @if (Model.Activo)
                {
                    <span class="badge bg-success">Activo</span>
                }
                else
                {
                    <span class="badge bg-danger">Inactivo</span>
                }
            </div>

            <h3 class="mt-4">Lecciones del Curso</h3>
            @if (Model.Lecciones != null && Model.Lecciones.Any())
            {
                <div class="list-group">
                    @foreach (var leccion in Model.Lecciones.OrderBy(l => l.Orden))
                    {
                        <div class="list-group-item">
                            <h5>@leccion.Orden. @leccion.Titulo</h5>
                            <p class="mb-1">@leccion.Contenido.Substring(0, Math.Min(100, leccion.Contenido.Length))...</p>
                            
                            @if (User.IsInRole("PROFESOR") && Model.IdProfesor == int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0"))
                            {
                                <div class="mt-2">
                                    <a asp-controller="Lesson" asp-action="Edit" asp-route-id="@leccion.IdLeccion" class="btn btn-sm btn-warning">Editar</a>
                                    <a asp-controller="Lesson" asp-action="Delete" asp-route-id="@leccion.IdLeccion" class="btn btn-sm btn-danger">Eliminar</a>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">Este curso aún no tiene lecciones.</div>
            }

            @if (User.IsInRole("PROFESOR") && Model.IdProfesor == int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0"))
            {
                <div class="mt-3">
                    <a asp-controller="Lesson" asp-action="Create" asp-route-cursoId="@Model.IdCurso" class="btn btn-primary">Ańadir Lección</a>
                    <a asp-action="Edit" asp-route-id="@Model.IdCurso" class="btn btn-warning">Editar Curso</a>
                    <a asp-action="Delete" asp-route-id="@Model.IdCurso" class="btn btn-danger">Eliminar Curso</a>
                </div>
            }
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Información del Curso</h5>
                    <ul class="list-unstyled">
                        <li><strong>Total Lecciones:</strong> @(Model.Lecciones?.Count ?? 0)</li>
                        <li><strong>Profesor:</strong> @Model.Profesor?.Nombre @Model.Profesor?.Apellidos</li>
                    </ul>
                    
                    @if (User.IsInRole("ALUMNO"))
                    {
                         <form asp-controller="Enrollment" asp-action="Inscribir" method="post" class="payment-form">
                            <input type="hidden" name="idCurso" value="@Model.IdCurso" />
                             @if (Model.Precio > 0)
                             {
                                 <div class="mb-2">
                                     <label class="form-label">Método de pago</label>
                                     <select name="metodoPago" class="form-select form-select-sm payment-method-select">
                                         <option value="">Selecciona...</option>
                                         @if (Model.AceptaEfectivo)
                                         {
                                             <option value="EFECTIVO">Efectivo</option>
                                         }
                                         @if (Model.AceptaTarjeta)
                                         {
                                             <option value="TARJETA">Tarjeta</option>
                                         }
                                         @if (Model.AceptaTransferencia)
                                         {
                                             <option value="TRANSFERENCIA">Transferencia</option>
                                         }
                                     </select>
                                 </div>

                                 <div class="stripe-fields border rounded p-2 mb-2" style="display:none;">
                                     <small class="text-muted d-block mb-2">Pago con tarjeta</small>
                                     <input name="cardHolderName" class="form-control form-control-sm mb-2" placeholder="Titular de la tarjeta" />
                                     <input name="cardNumber" class="form-control form-control-sm mb-2" placeholder="Número de tarjeta" />
                                     <div class="row g-2">
                                         <div class="col-6">
                                             <input name="cardExpiry" class="form-control form-control-sm" placeholder="MM/AA" />
                                         </div>
                                         <div class="col-6">
                                             <input name="cardCvc" class="form-control form-control-sm" placeholder="CVC" />
                                         </div>
                                     </div>
                                 </div>

                                 <div class="transfer-fields border rounded p-2 mb-2" style="display:none;">
                                     <small class="text-muted d-block mb-2">Datos de transferencia</small>
                                     <input name="transferAccountHolder" class="form-control form-control-sm mb-2" placeholder="Titular de la cuenta" />
                                     <input name="transferIban" class="form-control form-control-sm mb-2" placeholder="IBAN" />
                                     <input name="transferBankName" class="form-control form-control-sm mb-2" placeholder="Banco" />
                                     <input name="transferReference" class="form-control form-control-sm" placeholder="Concepto / Referencia" />
                                 </div>
                             }
                            <button type="submit" class="btn btn-success w-100">Inscribirse</button>
                        </form>
                    }
                </div>
            </div>

@section Scripts {
    <script>
        document.querySelectorAll('.payment-form').forEach(function (form) {
            const methodSelect = form.querySelector('.payment-method-select');
            const stripeFields = form.querySelector('.stripe-fields');
            const transferFields = form.querySelector('.transfer-fields');
            if (!methodSelect) return;

            const toggleFields = function () {
                const method = methodSelect.value;
                if (stripeFields) stripeFields.style.display = method === 'TARJETA' ? 'block' : 'none';
                if (transferFields) transferFields.style.display = method === 'TRANSFERENCIA' ? 'block' : 'none';
            };

            methodSelect.addEventListener('change', toggleFields);
            toggleFields();
        });
    </script>
}
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Volver a la Lista</a>
    </div>
</div>
