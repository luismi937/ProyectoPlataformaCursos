@model IEnumerable<ProyectoPlataformaCursos.Models.ViewModels.CursoViewModel>

@{
    ViewData["Title"] = "Cursos Disponibles";
}

<div class="container mt-4">
    <h1 class="mb-4">Cursos Disponibles</h1>

    <div class="row mb-3">
        <div class="col-md-6">
            <input id="courseSearchInput" type="text" class="form-control" placeholder="Buscar curso por título, profesor o descripción..." />
        </div>
    </div>

    @if (User.IsInRole("PROFESOR") || User.IsInRole("ADMIN"))
    {
        <div class="mb-3">
            <a asp-action="MisCursos" class="btn btn-info">Ver Mis Cursos</a>
            <a asp-action="Create" class="btn btn-primary">Crear Curso</a>
        </div>
    }

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var curso in Model)
            {
                <div class="col-md-4 mb-4 course-item" data-search="@($"{curso.Titulo} {curso.Descripcion} {curso.NombreProfesor}".ToLowerInvariant())">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@curso.Titulo</h5>
                            <p class="card-text">@curso.Descripcion</p>
                            <p class="text-muted">
                                <small>Profesor: @curso.NombreProfesor</small><br />
                                <small>Lecciones: @curso.NumeroLecciones</small><br />
                                <small>Precio: @(curso.Precio > 0 ? $"{curso.Precio:N2} €" : "Gratis")</small><br />
                                <small>Pago: @(!string.IsNullOrWhiteSpace(curso.FormasPagoDisponibles) ? curso.FormasPagoDisponibles : "No requerido")</small>
                            </p>

                            @if (curso.EstaInscrito)
                            {
                                <div class="progress mb-2">
                                    <div class="progress-bar" role="progressbar" style="width: @curso.ProgresoPercentage%">
                                        @curso.ProgresoPercentage%
                                    </div>
                                </div>
                                <span class="badge bg-success">Inscrito</span>
                            }
                        </div>
                        <div class="card-footer">
                            <a asp-action="Details" asp-route-id="@curso.IdCurso" class="btn btn-primary btn-sm">Ver Detalles</a>
                            
                            @if (User.IsInRole("ALUMNO") && !curso.EstaInscrito)
                            {
                                <form asp-controller="Enrollment" asp-action="Inscribir" method="post" class="payment-form d-inline">
                                    <input type="hidden" name="idCurso" value="@curso.IdCurso" />
                                     @if (curso.Precio > 0)
                                     {
                                         <select name="metodoPago" class="form-select form-select-sm d-inline-block mb-2 payment-method-select" style="width: 160px;">
                                             <option value="">Pago...</option>
                                             @if (curso.AceptaEfectivo)
                                             {
                                                 <option value="EFECTIVO">Efectivo</option>
                                             }
                                             @if (curso.AceptaTarjeta)
                                             {
                                                 <option value="TARJETA">Tarjeta</option>
                                             }
                                             @if (curso.AceptaTransferencia)
                                             {
                                                 <option value="TRANSFERENCIA">Transferencia</option>
                                             }
                                         </select>

                                          <div class="stripe-fields border rounded p-2 mb-2" style="display:none;">
                                             <small class="text-muted d-block mb-1">Pago con tarjeta</small>
                                              <input name="cardHolderName" class="form-control form-control-sm mb-1" placeholder="Titular" />
                                              <input name="cardNumber" class="form-control form-control-sm mb-1 card-number" placeholder="Nº tarjeta" inputmode="numeric" maxlength="19" />
                                             <div class="row g-1">
                                                  <div class="col-6"><input name="cardExpiry" class="form-control form-control-sm card-expiry" placeholder="MM/AA" inputmode="numeric" maxlength="5" /></div>
                                                  <div class="col-6"><input name="cardCvc" class="form-control form-control-sm card-cvc" placeholder="CVC" inputmode="numeric" maxlength="4" /></div>
                                             </div>
                                         </div>

                                         <div class="transfer-fields border rounded p-2 mb-2" style="display:none;">
                                             <small class="text-muted d-block mb-1">Transferencia</small>
                                             <input name="transferAccountHolder" class="form-control form-control-sm mb-1" placeholder="Titular" />
                                             <input name="transferIban" class="form-control form-control-sm mb-1" placeholder="IBAN" />
                                             <input name="transferBankName" class="form-control form-control-sm mb-1" placeholder="Banco" />
                                             <input name="transferReference" class="form-control form-control-sm" placeholder="Referencia" />
                                         </div>
                                     }
                                    <button type="submit" class="btn btn-success btn-sm">Inscribirse</button>
                                </form>
                            }
                            
                            @if (curso.EstaInscrito)
                            {
                                <a asp-controller="Lesson" asp-action="View" asp-route-cursoId="@curso.IdCurso" class="btn btn-info btn-sm">Ver Lecciones</a>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info">No hay cursos disponibles en este momento.</div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        const normalize = (v) => (v || '').toString().toLowerCase().trim();

        const searchInput = document.getElementById('courseSearchInput');
        if (searchInput) {
            searchInput.addEventListener('input', function () {
                const term = normalize(this.value);
                document.querySelectorAll('.course-item').forEach(function (item) {
                    const text = item.getAttribute('data-search') || '';
                    item.style.display = text.includes(term) ? '' : 'none';
                });
            });
        }

        document.querySelectorAll('.payment-form').forEach(function (form) {
            const methodSelect = form.querySelector('.payment-method-select');
            const stripeFields = form.querySelector('.stripe-fields');
            const transferFields = form.querySelector('.transfer-fields');
            const cardNumber = form.querySelector('.card-number');
            const cardExpiry = form.querySelector('.card-expiry');
            const cardCvc = form.querySelector('.card-cvc');
            if (!methodSelect) return;

            const toggleFields = function () {
                const method = methodSelect.value;
                if (stripeFields) stripeFields.style.display = method === 'TARJETA' ? 'block' : 'none';
                if (transferFields) transferFields.style.display = method === 'TRANSFERENCIA' ? 'block' : 'none';
            };

            methodSelect.addEventListener('change', toggleFields);
            toggleFields();

            if (cardNumber) {
                cardNumber.addEventListener('input', function () {
                    const digits = this.value.replace(/\D/g, '').slice(0, 16);
                    this.value = digits.replace(/(.{4})/g, '$1 ').trim();
                });
            }

            if (cardExpiry) {
                cardExpiry.addEventListener('input', function () {
                    const digits = this.value.replace(/\D/g, '').slice(0, 4);
                    this.value = digits.length > 2 ? `${digits.slice(0, 2)}/${digits.slice(2)}` : digits;
                });
            }

            if (cardCvc) {
                cardCvc.addEventListener('input', function () {
                    this.value = this.value.replace(/\D/g, '').slice(0, 4);
                });
            }

            form.addEventListener('submit', function (e) {
                const method = methodSelect.value;
                if (method === 'TARJETA') {
                    const holder = form.querySelector('input[name="cardHolderName"]')?.value?.trim();
                    const number = form.querySelector('input[name="cardNumber"]')?.value?.replace(/\s/g, '');
                    const expiry = form.querySelector('input[name="cardExpiry"]')?.value?.trim();
                    const cvc = form.querySelector('input[name="cardCvc"]')?.value?.trim();

                    if (!holder || !number || !expiry || !cvc || number.length < 13 || !/^\d{2}\/\d{2}$/.test(expiry)) {
                        e.preventDefault();
                        alert('Revisa los datos de pago con tarjeta antes de continuar.');
                    }
                }

                if (method === 'TRANSFERENCIA') {
                    const iban = form.querySelector('input[name="transferIban"]')?.value?.replace(/\s/g, '');
                    const bank = form.querySelector('input[name="transferBankName"]')?.value?.trim();
                    const holder = form.querySelector('input[name="transferAccountHolder"]')?.value?.trim();
                    const reference = form.querySelector('input[name="transferReference"]')?.value?.trim();

                    if (!iban || iban.length < 10 || !bank || !holder || !reference) {
                        e.preventDefault();
                        alert('Completa correctamente los datos de transferencia.');
                    }
                }
            });
        });
    </script>
}
