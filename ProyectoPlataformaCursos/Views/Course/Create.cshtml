@model ProyectoPlataformaCursos.Models.Curso

@{
    ViewData["Title"] = "Crear Curso";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <h2 class="card-title">Crear Nuevo Curso</h2>

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Titulo" class="form-label"></label>
                            <input asp-for="Titulo" class="form-control" />
                            <span asp-validation-for="Titulo" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Descripcion" class="form-label"></label>
                            <textarea asp-for="Descripcion" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="Activo" class="form-check-input" checked />
                            <label asp-for="Activo" class="form-check-label"></label>
                        </div>

                        @if (User.IsInRole("ADMIN"))
                        {
                            <div class="form-group mb-3">
                                <label asp-for="IdProfesor" class="form-label">Profesor asignado</label>
                                <select asp-for="IdProfesor" asp-items="ViewBag.Profesores" class="form-select">
                                    <option value="">Selecciona un profesor...</option>
                                </select>
                                <span asp-validation-for="IdProfesor" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Precio" class="form-label">Precio (€)</label>
                                <input asp-for="Precio" type="number" min="0" step="0.01" class="form-control" />
                                <span asp-validation-for="Precio" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Métodos de pago</label>
                                <div class="form-check">
                                    <input asp-for="AceptaEfectivo" class="form-check-input" />
                                    <label asp-for="AceptaEfectivo" class="form-check-label">Efectivo</label>
                                </div>
                                <div class="form-check">
                                    <input asp-for="AceptaTarjeta" class="form-check-input" />
                                    <label asp-for="AceptaTarjeta" class="form-check-label">Tarjeta</label>
                                </div>
                                <div class="form-check">
                                    <input asp-for="AceptaTransferencia" class="form-check-input" />
                                    <label asp-for="AceptaTransferencia" class="form-check-label">Transferencia</label>
                                </div>
                            </div>
                        }

                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary">Crear Curso</button>
                            <a asp-action="MisCursos" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
