@model ProyectoPlataformaCursos.Models.Curso

@{
    ViewData["Title"] = "Editar Curso";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <h2 class="card-title">Editar Curso</h2>

                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="IdCurso" />
                        @if (!User.IsInRole("ADMIN"))
                        {
                            <input type="hidden" asp-for="IdProfesor" />
                        }
                        <input type="hidden" asp-for="FechaCreacion" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Titulo" class="form-label"></label>
                            <input asp-for="Titulo" class="form-control" />
                            <span asp-validation-for="Titulo" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Descripcion" class="form-label"></label>
                            <textarea asp-for="Descripcion" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="Activo" class="form-check-input" />
                            <label asp-for="Activo" class="form-check-label"></label>
                        </div>

                        @if (User.IsInRole("ADMIN"))
                        {
                            <div class="form-group mb-3">
                                <label asp-for="IdProfesor" class="form-label">Profesor asignado</label>
                                <select asp-for="IdProfesor" asp-items="ViewBag.Profesores" class="form-select">
                                    <option value="">Selecciona un profesor...</option>
                                </select>
                                <span asp-validation-for="IdProfesor" class="text-danger"></span>
                            </div>
                        }

                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                            <a asp-action="MisCursos" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
