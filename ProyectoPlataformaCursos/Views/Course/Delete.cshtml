@model ProyectoPlataformaCursos.Models.Curso

@{
    ViewData["Title"] = "Eliminar Curso";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <h2 class="card-title text-danger">Eliminar Curso</h2>
                    <div class="alert alert-warning">
                        <strong>øEst·s seguro de que deseas eliminar este curso?</strong>
                        <p>Esta acciÛn no se puede deshacer y eliminar· todas las lecciones asociadas.</p>
                    </div>

                    <dl class="row">
                        <dt class="col-sm-3">TÌtulo:</dt>
                        <dd class="col-sm-9">@Model.Titulo</dd>

                        <dt class="col-sm-3">DescripciÛn:</dt>
                        <dd class="col-sm-9">@Model.Descripcion</dd>

                        <dt class="col-sm-3">Fecha de CreaciÛn:</dt>
                        <dd class="col-sm-9">@Model.FechaCreacion.ToShortDateString()</dd>

                        <dt class="col-sm-3">Lecciones:</dt>
                        <dd class="col-sm-9">@(Model.Lecciones?.Count ?? 0)</dd>
                    </dl>

                    <form asp-action="Delete" method="post" id="deleteCourseForm">
                        <input type="hidden" asp-for="IdCurso" />
                        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal">Confirmar EliminaciÛn</button>
                        <a asp-action="MisCursos" class="btn btn-secondary">Cancelar</a>
                    </form>

                    <div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Confirmar eliminaciÛn</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    øSeguro que quieres eliminar el curso <strong>@Model.Titulo</strong>? Esta acciÛn es irreversible.
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                    <button type="submit" class="btn btn-danger" form="deleteCourseForm">SÌ, eliminar</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
