@{
    ViewData["Title"] = "Plataforma de Cursos";
}

<div class="container mt-4">
    <div class="p-5 rounded-4 hero-panel text-center mb-4">
        <h1 class="display-5 fw-bold">Bienvenido a la Plataforma de Cursos</h1>
        <p class="lead mb-4">Aprende a tu ritmo con contenidos prácticos y seguimiento de progreso.</p>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <p class="mb-3">Hola, <strong>@User.Identity.Name</strong></p>

            @if (User.IsInRole("ALUMNO"))
            {
                <a asp-controller="Enrollment" asp-action="MisCursos" class="btn btn-primary me-2 mb-2">Mis Cursos</a>
                <a asp-controller="Course" asp-action="Index" class="btn btn-outline-primary mb-2">Explorar Cursos</a>
            }
            else if (User.IsInRole("PROFESOR"))
            {
                <a asp-controller="Course" asp-action="MisCursos" class="btn btn-primary me-2 mb-2">Mis Cursos</a>
                <a asp-controller="Course" asp-action="Create" class="btn btn-outline-primary mb-2">Crear Curso</a>
            }
            else if (User.IsInRole("ADMIN"))
            {
                <a asp-controller="Admin" asp-action="Index" class="btn btn-primary me-2 mb-2">Panel de Administración</a>
                <a asp-controller="Course" asp-action="Create" class="btn btn-outline-primary mb-2">Crear Curso</a>
            }
        }
        else
        {
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary me-2">Registrarse</a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">Iniciar Sesión</a>
        }
    </div>

    @if (ViewBag.CursosDestacados != null)
    {
        <div class="mt-5">
            <h2 class="text-center mb-4 fw-bold">
                <i class="bi bi-star-fill"></i> Cursos Destacados
            </h2>
            <div class="row">
                @foreach (var curso in ViewBag.CursosDestacados)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body">
                                <h5 class="card-title">@curso.Titulo</h5>
                                <p class="card-text">@curso.Descripcion.Substring(0, Math.Min(100, curso.Descripcion.Length))...</p>
                                <p class="text-muted">
                                    <small><i class="bi bi-person"></i> @curso.NombreProfesor</small><br />
                                    <small><i class="bi bi-book"></i> @curso.NumeroLecciones lecciones</small>
                                </p>
                            </div>
                            <div class="card-footer bg-transparent">
                                <a asp-controller="Course" asp-action="Details" asp-route-id="@curso.IdCurso" class="btn btn-primary btn-sm w-100">
                                    <i class="bi bi-eye"></i> Ver Detalles
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="text-center mt-3">
                <a asp-controller="Course" asp-action="Index" class="btn btn-outline-primary btn-lg">
                    <i class="bi bi-grid-3x3"></i> Ver Todos los Cursos
                </a>
            </div>
        </div>
    }

    <div class="row mt-5 mb-5">
        <div class="col-md-4 text-center">
            <div class="feature-box p-4 h-100">
                <i class="bi bi-book display-4 text-primary"></i>
                <h3 class="mt-3">Variedad de Cursos</h3>
                <p>Accede a una amplia selección de cursos en diferentes categorías</p>
            </div>
        </div>
        <div class="col-md-4 text-center">
            <div class="feature-box p-4 h-100">
                <i class="bi bi-people display-4 text-primary"></i>
                <h3 class="mt-3">Profesores Expertos</h3>
                <p>Aprende de profesionales con experiencia en sus campos</p>
            </div>
        </div>
        <div class="col-md-4 text-center">
            <div class="feature-box p-4 h-100">
                <i class="bi bi-trophy display-4 text-primary"></i>
                <h3 class="mt-3">Aprende a tu Ritmo</h3>
                <p>Estudia cuando quieras y sigue tu progreso en tiempo real</p>
            </div>
        </div>
    </div>
</div>

<style>
    .hero-panel {
        background: linear-gradient(135deg, #eef4ff 0%, #f7fbff 100%);
        border: 1px solid #d9e8ff;
    }

    .feature-box {
        border: 1px solid #dde6f5;
        border-radius: 12px;
        background: #fff;
    }
</style>
