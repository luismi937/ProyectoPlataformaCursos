@model IEnumerable<ProyectoPlataformaCursos.Models.Curso>

@{
    ViewData["Title"] = "Gestión de Cursos";
}

<div class="container mt-4">
    <h1 class="mb-4">Gestión de Cursos</h1>

    <div class="mb-3">
        <a asp-action="Index" class="btn btn-secondary">Volver al Panel</a>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Título</th>
                            <th>Profesor</th>
                            <th>Lecciones</th>
                            <th>Fecha Creación</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var curso in Model)
                            {
                                <tr>
                                    <td>@curso.IdCurso</td>
                                    <td>@curso.Titulo</td>
                                    <td>@curso.Profesor?.Nombre @curso.Profesor?.Apellidos</td>
                                    <td>@(curso.Lecciones?.Count ?? 0)</td>
                                    <td>@curso.FechaCreacion.ToShortDateString()</td>
                                    <td>@curso.Precio.ToString("N2") €</td>
                                    <td>
                                        @if (curso.Precio <= 0)
                                        {
                                            <span class="badge bg-secondary">Curso gratuito</span>
                                        }
                                        else
                                        {
                                            <small>
                                                @if (curso.AceptaEfectivo)
                                                {
                                                    <span class="badge bg-light text-dark">Efectivo</span>
                                                }
                                                @if (curso.AceptaTarjeta)
                                                {
                                                    <span class="badge bg-light text-dark">Tarjeta</span>
                                                }
                                                @if (curso.AceptaTransferencia)
                                                {
                                                    <span class="badge bg-light text-dark">Transferencia</span>
                                                }
                                            </small>
                                        }
                                    </td>
                                    <td>
                                        @if (curso.Activo)
                                        {
                                            <span class="badge bg-success">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactivo</span>
                                        }
                                    </td>
                                    <td>
                                        <form asp-action="ToggleCursoActivo" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@curso.IdCurso" />
                                            <button type="submit" class="btn btn-warning btn-sm">
                                                @if (curso.Activo)
                                                {
                                                    <text>Desactivar</text>
                                                }
                                                else
                                                {
                                                    <text>Activar</text>
                                                }
                                            </button>
                                        </form>
                                        <a asp-controller="Course" asp-action="Details" asp-route-id="@curso.IdCurso" class="btn btn-info btn-sm">Ver</a>
                                         <a asp-action="ConfigurarCurso" asp-route-id="@curso.IdCurso" class="btn btn-primary btn-sm">Configurar</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center">No hay cursos registrados</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
