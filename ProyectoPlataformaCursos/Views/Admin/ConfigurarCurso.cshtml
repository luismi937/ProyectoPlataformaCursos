@model ProyectoPlataformaCursos.Models.ViewModels.AdminCursoPagoViewModel

@{
    ViewData["Title"] = "Configurar Curso";
}

<div class="container mt-4">
    <h1 class="mb-4">Configurar Curso (Admin)</h1>

    <div class="card">
        <div class="card-body">
            <form asp-action="ConfigurarCurso" method="post">
                <input asp-for="IdCurso" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Titulo" class="form-label"></label>
                    <input asp-for="Titulo" class="form-control" />
                    <span asp-validation-for="Titulo" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Precio" class="form-label">Precio (€)</label>
                    <input asp-for="Precio" class="form-control" type="number" min="0" step="0.01" />
                    <span asp-validation-for="Precio" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="Activo" class="form-check-input" />
                    <label asp-for="Activo" class="form-check-label">Curso Activo</label>
                </div>

                <h5 class="mt-4">Formas de pago permitidas</h5>

                <div class="form-check">
                    <input asp-for="AceptaEfectivo" class="form-check-input" />
                    <label asp-for="AceptaEfectivo" class="form-check-label">Efectivo</label>
                </div>
                <div class="form-check">
                    <input asp-for="AceptaTarjeta" class="form-check-input" />
                    <label asp-for="AceptaTarjeta" class="form-check-label">Tarjeta</label>
                </div>
                <div class="form-check mb-4">
                    <input asp-for="AceptaTransferencia" class="form-check-input" />
                    <label asp-for="AceptaTransferencia" class="form-check-label">Transferencia</label>
                </div>

                <button type="submit" class="btn btn-primary">Guardar configuración</button>
                <a asp-action="Cursos" class="btn btn-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}