@{
    ViewData["Title"] = "Panel de Administración";
    decimal ingresoTotal = ViewBag.IngresoTotal is decimal d ? d : 0m;
}

<div class="container mt-4">
    <h1 class="mb-4">Panel de Administración</h1>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-people"></i> Total Usuarios
                    </h5>
                    <h2 class="card-text">@ViewBag.TotalUsuarios</h2>
                </div>
                <div class="card-footer">
                    <a asp-action="Usuarios" class="text-white">Ver todos ?</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-book"></i> Total Cursos
                    </h5>
                    <h2 class="card-text">@ViewBag.TotalCursos</h2>
                </div>
                <div class="card-footer">
                    <a asp-action="Cursos" class="text-white">Ver todos ?</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-person-check"></i> Total Inscripciones
                    </h5>
                    <h2 class="card-text">@ViewBag.TotalInscripciones</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card text-white bg-dark">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-cash-stack"></i> Ingresos Totales
                    </h5>
                    <h2 class="card-text">@ingresoTotal.ToString("N2") €</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h5>Accesos Rápidos</h5>
                </div>
                <div class="list-group list-group-flush">
                    <a asp-action="Usuarios" class="list-group-item list-group-item-action">
                        <i class="bi bi-people"></i> Gestionar Usuarios
                    </a>
                    <a asp-action="Cursos" class="list-group-item list-group-item-action">
                        <i class="bi bi-book"></i> Gestionar Cursos
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h5>Información del Sistema</h5>
                </div>
                <div class="card-body">
                    <p><strong>Fecha:</strong> @DateTime.Now.ToLongDateString()</p>
                    <p><strong>Hora:</strong> @DateTime.Now.ToShortTimeString()</p>
                    <p><strong>Estado:</strong> <span class="badge bg-success">Sistema Operativo</span></p>
                </div>
            </div>
        </div>
    </div>
</div>
