@model IEnumerable<ProyectoPlataformaCursos.Models.Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container mt-4">
    <h1 class="mb-4">Gestión de Usuarios</h1>

    <div class="mb-3">
        <a asp-action="Index" class="btn btn-secondary">Volver al Panel</a>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Email</th>
                            <th>Rol</th>
                            <th>Fecha Registro</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var usuario in Model)
                            {
                                <tr>
                                    <td>@usuario.Id</td>
                                    <td>@usuario.Nombre @usuario.Apellidos</td>
                                    <td>@usuario.Email</td>
                                    <td>
                                        @if (usuario.Rol == "ADMIN")
                                        {
                                            <span class="badge bg-danger">@usuario.Rol</span>
                                        }
                                        else if (usuario.Rol == "PROFESOR")
                                        {
                                            <span class="badge bg-primary">@usuario.Rol</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">@usuario.Rol</span>
                                        }
                                    </td>
                                    <td>@usuario.FechaRegistro.ToShortDateString()</td>
                                    <td>
                                        @if (usuario.Rol != "ADMIN")
                                        {
                                            <form asp-action="EliminarUsuario" method="post" class="d-inline" onsubmit="return confirm('żEstás seguro de eliminar este usuario?');">
                                                <input type="hidden" name="id" value="@usuario.Id" />
                                                <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Protegido</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center">No hay usuarios registrados</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
